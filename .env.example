MEMFORGE_APP_NAME=MemForge
MEMFORGE_ENV=development
MEMFORGE_DEBUG=true
MEMFORGE_HOST=127.0.0.1
MEMFORGE_PORT=8000

MEMFORGE_DATABASE_URL=sqlite:///./memforge.db
MEMFORGE_VECTOR_BACKEND=simple
MEMFORGE_VECTOR_DIR=./.memforge/vectors

MEMFORGE_EMBEDDING_PROVIDER=dummy
MEMFORGE_EMBEDDING_MODEL=local-default

MEMFORGE_LOG_LEVEL=INFO
